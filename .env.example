# Supabase 환경변수
# Supabase 대시보드 → Project Settings → API 에서 복사

# 프로젝트 URL (브라우저에 노출됨, 안전)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Anonymous public key (브라우저에 노출됨, 안전 — RLS로 보호)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Service role key (🔴 절대 클라이언트에 노출 금지! 서버 코드에서만 사용)
# RLS를 우회하므로 매칭 판정/CSV 익스포트 등 Edge Function에서만 사용
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# 사이트 URL (QR 코드 생성용)
# 로컬: http://localhost:3001
# 프로덕션: https://your-domain.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3001
